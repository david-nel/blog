---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'David Nel',
  description = 'Notes on programming, technical side projects, and learning the craft.',
} = Astro.props;

const pageTitle = title === 'David Nel' ? title : `${title} - David Nel`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="canonical" href={Astro.url} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="alternate" type="application/rss+xml" title="David Nel RSS" href="/rss.xml" />
    <title>{pageTitle}</title>
  </head>
  <body>
    <div class="site-shell">
      <header class="site-header">
        <a class="brand" href="/">David Nel</a>
        <nav aria-label="Primary navigation">
          <a href="/">Home</a>
          <a href="/blog">Blog</a>
          <a href="/newsletter">Newsletter</a>
          <a href="/rss.xml">RSS</a>
        </nav>
      </header>
      <main>
        <slot />
      </main>
      <footer class="site-footer">
        <span>© {new Date().getFullYear()} David Nel</span>
      </footer>
    </div>
    <script is:inline type="text/javascript" async src="https://subscribe-forms.beehiiv.com/attribution.js"></script>
  </body>
</html>
