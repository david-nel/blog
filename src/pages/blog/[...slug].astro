---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import NewsletterSignup from '../../components/NewsletterSignup.astro';
import SeriesTimeline from '../../components/SeriesTimeline.astro';
import { formatDate, getPublishedPosts, slugify, sortSeriesPosts } from '../../lib/posts';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((post) => ({ params: { slug: post.id }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const allPosts = await getPublishedPosts();
const seriesPosts = post.data.series
  ? sortSeriesPosts(allPosts.filter((entry) => entry.data.series === post.data.series))
  : [];
const currentSeriesIndex = seriesPosts.findIndex((entry) => entry.id === post.id);
const previousSeriesPost = currentSeriesIndex > 0 ? seriesPosts[currentSeriesIndex - 1] : undefined;
const nextSeriesPost =
  currentSeriesIndex >= 0 && currentSeriesIndex < seriesPosts.length - 1
    ? seriesPosts[currentSeriesIndex + 1]
    : undefined;
const seriesDescription = seriesPosts.find((entry) => entry.data.seriesDescription)?.data.seriesDescription;
---

<BaseLayout title={post.data.title} description={post.data.description}>
  <article class="post">
    <header class="post-header">
      <h1>{post.data.title}</h1>
      <p class="post-date post-dates">
        <span>
          Published <time datetime={post.data.pubDate.toISOString()}>{formatDate(post.data.pubDate)}</time>
        </span>
        {
          post.data.updatedDate && (
            <span>
              <span aria-hidden="true">|</span>
              Last updated <time datetime={post.data.updatedDate.toISOString()}>{formatDate(post.data.updatedDate)}</time>
            </span>
          )
        }
      </p>
      <p>{post.data.description}</p>
      <div class="meta-row">
        {post.data.tags.map((tag) => <a href={`/tags/${slugify(tag)}/`}>#{tag}</a>)}
      </div>
    </header>

    {
      post.data.series && (
        <SeriesTimeline
          posts={seriesPosts}
          currentPostId={post.id}
          seriesName={post.data.series}
          seriesDescription={seriesDescription}
        />
      )
    }

    <div class="prose">
      <Content />
    </div>

    {
      post.data.series && (previousSeriesPost || nextSeriesPost) && (
        <nav class="series-nav" aria-label={`${post.data.series} series navigation`}>
          {previousSeriesPost ? (
            <a class="series-nav-link" href={`/blog/${previousSeriesPost.id}/`} rel="prev">
              <span>Previous in series</span>
              <strong>{previousSeriesPost.data.title}</strong>
            </a>
          ) : (
            <span></span>
          )}
          {nextSeriesPost && (
            <a class="series-nav-link next" href={`/blog/${nextSeriesPost.id}/`} rel="next">
              <span>Next in series</span>
              <strong>{nextSeriesPost.data.title}</strong>
            </a>
          )}
        </nav>
      )
    }
  </article>

  <NewsletterSignup compact />

  <section class="comments">
    <h2>Discussion</h2>
    <script
      is:inline
      src="https://giscus.app/client.js"
      data-repo="david-nel/blog"
      data-repo-id="R_kgDOSoRn9Q"
      data-category="Blog Comments"
      data-category-id="DIC_kwDOSoRn9c4C93-D"
      data-mapping="pathname"
      data-strict="0"
      data-reactions-enabled="1"
      data-emit-metadata="0"
      data-input-position="top"
      data-theme="preferred_color_scheme"
      data-lang="en"
      data-loading="lazy"
      crossorigin="anonymous"
      async
    ></script>
  </section>
</BaseLayout>
